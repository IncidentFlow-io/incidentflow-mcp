# ============================================================
# IncidentFlow MCP — local development environment
# Copy this file to .env and adjust values as needed.
# ============================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Environment: development | staging | production
# Setting to "production" disables /docs and /redoc.
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Auth — Bearer PAT for local HTTP MCP authentication
# ---------------------------------------------------------------------------
# Generate a token:
#   uv run incidentflow-mcp token create --name "local-dev"
#
# Or set a static dev token (convenient for curl / local scripts):
#   INCIDENTFLOW_PAT=if_pat_local_dev.your_secret_here
#
# Leave empty to run in UNPROTECTED mode (not recommended even locally).
INCIDENTFLOW_PAT=

# Scope enforcement — whether tokens must carry the required scope for each endpoint.
# Default: enabled in production, disabled in all other environments (dev-friendly).
# Override explicitly if needed:
#   ENFORCE_SCOPES=true   force enforcement even in development
#   ENFORCE_SCOPES=false  disable enforcement even in production (not recommended)
# ENFORCE_SCOPES=

# ---------------------------------------------------------------------------
# MCP server metadata
# ---------------------------------------------------------------------------
MCP_SERVER_NAME=incidentflow-mcp
MCP_SERVER_VERSION=0.1.0
# Idle timeout used for best-effort inferred MCP session termination metrics
MCP_SESSION_IDLE_TIMEOUT_SECONDS=1800

# ---------------------------------------------------------------------------
# Tool settings
# ---------------------------------------------------------------------------
# Maximum time window for alert correlation (in minutes)
MAX_ALERT_CORRELATION_WINDOW_MINUTES=60

# ---------------------------------------------------------------------------
# Rate limiting and distributed tool guards (Redis-backed)
# ---------------------------------------------------------------------------
# Example local URL with password:
# REDIS_URL=redis://:redis-dev-password@127.0.0.1:6379/0
REDIS_URL=redis://localhost:6379/0

# HTTP transport limits
RATE_LIMIT_UNAUTH_PER_MIN=20
RATE_LIMIT_AUTHENTICATED_PER_MIN=60

# MCP tools/call limits
TOOL_LIMIT_AUTHENTICATED_PER_MIN=20

# Stricter rate limit for expensive tools (per identity)
EXPENSIVE_TOOL_LIMIT_PER_MIN=5
# Comma-separated list of expensive tools
EXPENSIVE_TOOLS=incident_graph_build,large_correlation,slack_thread_mining,github_org_search

# Tool execution concurrency caps
TOOL_CONCURRENCY_AUTHENTICATED=2

# Bucket scope policy:
# ip | principal | workspace
RATE_LIMIT_UNAUTHENTICATED_BUCKET_SCOPE=ip
RATE_LIMIT_AUTHENTICATED_BUCKET_SCOPE=principal

# Tool execution timeout
TOOL_TIMEOUT_SECONDS=30
# Optional per-tool timeout overrides:
# TOOL_TIMEOUT_OVERRIDES=incident_summary=15,correlate_alerts=20
TOOL_TIMEOUT_OVERRIDES=

# Auth endpoints that should be transport-rate-limited (if present)
RATE_LIMIT_AUTH_ENDPOINTS=/authorize,/token,/register,/oauth/register
