# ============================================================
# IncidentFlow MCP — local development environment
# Copy this file to .env and adjust values as needed.
# ============================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Environment: development | staging | production
# Setting to "production" disables /docs and /redoc.
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Auth — Bearer PAT for local HTTP MCP authentication
# ---------------------------------------------------------------------------
# Generate a token:
#   uv run incidentflow-mcp token create --name "local-dev"
#
# Or set a static dev token (convenient for curl / local scripts):
#   INCIDENTFLOW_PAT=if_pat_local_dev.your_secret_here
#
# Leave empty to run in UNPROTECTED mode (not recommended even locally).
INCIDENTFLOW_PAT=

# Scope enforcement — whether tokens must carry the required scope for each endpoint.
# Default: enabled in production, disabled in all other environments (dev-friendly).
# Override explicitly if needed:
#   ENFORCE_SCOPES=true   force enforcement even in development
#   ENFORCE_SCOPES=false  disable enforcement even in production (not recommended)
# ENFORCE_SCOPES=

# ---------------------------------------------------------------------------
# MCP server metadata
# ---------------------------------------------------------------------------
MCP_SERVER_NAME=incidentflow-mcp
MCP_SERVER_VERSION=0.1.0

# ---------------------------------------------------------------------------
# Tool settings
# ---------------------------------------------------------------------------
# Maximum time window for alert correlation (in minutes)
MAX_ALERT_CORRELATION_WINDOW_MINUTES=60
