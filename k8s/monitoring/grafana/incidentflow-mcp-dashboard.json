  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "incidentflow",
    "mcp",
    "prometheus",
    "tools"
  ],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "query": "label_values(http_requests_total, namespace)",
          "refId": "namespace"
        },
        "definition": "label_values(http_requests_total, namespace)",
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": ".*",
          "selected": true
        },
        "allValue": ".*",
        "regex": ""
      },
      {
        "name": "pod",
        "label": "pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "query": "label_values(http_requests_total{namespace=~\"$namespace\"}, pod)",
          "refId": "pod"
        },
        "definition": "label_values(http_requests_total{namespace=~\"$namespace\"}, pod)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": ".*",
          "selected": true
        },
        "allValue": ".*",
        "regex": ""
      },
      {
        "name": "tool",
        "label": "tool",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "query": "label_values(mcp_tool_requests_total{namespace=~\"$namespace\",pod=~\"$pod\",traffic_type=\"business\"}, tool)",
          "refId": "tool"
        },
        "definition": "label_values(mcp_tool_requests_total{namespace=~\"$namespace\",pod=~\"$pod\",traffic_type=\"business\"}, tool)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": ".*",
          "selected": true
        },
        "regex": "",
        "sort": 1,
        "options": [],
        "allValue": ".*"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
  "title": "IncidentFlow MCP Observability",
  "uid": "incidentflow-mcp-observability",
  "version": 2,
