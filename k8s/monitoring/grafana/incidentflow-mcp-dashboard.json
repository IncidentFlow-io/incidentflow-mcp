{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS}"
  },
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "MCP RPS",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{route=\"/mcp\",traffic=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m]))",
          "legendFormat": "RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      }
    },
    {
      "id": 2,
      "title": "MCP Error Rate",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_request_errors_total{route=\"/mcp\",traffic=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m])) / clamp_min(sum(rate(http_requests_total{route=\"/mcp\",traffic=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m])), 0.001)",
          "legendFormat": "Error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      }
    },
    {
      "id": 3,
      "title": "MCP Latency p95",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{route=\"/mcp\",traffic=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      }
    },
    {
      "id": 4,
      "title": "Active MCP Sessions",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(mcp_sessions_active{namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"})",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      }
    },
    {
      "id": 5,
      "title": "MCP Request Rate by Status Code",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_code) (rate(http_requests_total{route=\"/mcp\",traffic=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 6,
      "title": "MCP Latency (p50/p95/p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{route=\"/mcp\",traffic=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{route=\"/mcp\",traffic=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "1000 * histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{route=\"/mcp\",traffic=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 7,
      "title": "Top MCP Request Types",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (request_type) (rate(mcp_request_type_total{namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m])))",
          "legendFormat": "{{request_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 8,
      "title": "Top MCP Tools by RPS",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (tool) (rate(mcp_tool_requests_total{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m])))",
          "legendFormat": "{{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 9,
      "title": "MCP Tool Request Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool) (rate(mcp_tool_requests_total{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m]))",
          "legendFormat": "{{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 10,
      "title": "MCP Tool p50/p95/p99 Latency",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * histogram_quantile(0.50, sum by (le, tool) (rate(mcp_tool_request_duration_seconds_bucket{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m])))",
          "legendFormat": "{{tool}} p50"
        },
        {
          "refId": "B",
          "expr": "1000 * histogram_quantile(0.95, sum by (le, tool) (rate(mcp_tool_request_duration_seconds_bucket{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m])))",
          "legendFormat": "{{tool}} p95"
        },
        {
          "refId": "C",
          "expr": "1000 * histogram_quantile(0.99, sum by (le, tool) (rate(mcp_tool_request_duration_seconds_bucket{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m])))",
          "legendFormat": "{{tool}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 11,
      "title": "MCP Tool Error Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool) (rate(mcp_tool_requests_total{traffic_type=\"business\",outcome=\"error\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m])) / clamp_min(sum by (tool) (rate(mcp_tool_requests_total{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m])), 0.001)",
          "legendFormat": "{{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 12,
      "title": "Per-Pod Tool p95 Latency",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 21
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * histogram_quantile(0.95, sum by (le, pod, tool) (rate(mcp_tool_request_duration_seconds_bucket{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m])))",
          "legendFormat": "{{pod}} / {{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 13,
      "title": "MCP Activity (sessions vs connections)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 21
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(mcp_sessions_active{namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"})",
          "legendFormat": "sessions_active"
        },
        {
          "refId": "B",
          "expr": "sum(mcp_connections_active{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"})",
          "legendFormat": "connections_active"
        },
        {
          "refId": "C",
          "expr": "sum by (reason) (rate(mcp_sessions_started_total{namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m]))",
          "legendFormat": "starts/{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 14,
      "title": "Unknown Tool Ratio",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 29
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mcp_tool_requests_total{tool=\"unknown\",traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m])) / clamp_min(sum(rate(mcp_tool_requests_total{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m])), 0.001)",
          "legendFormat": "unknown ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      }
    },
    {
      "id": 15,
      "title": "Probe vs Business Traffic",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 5,
        "w": 9,
        "x": 6,
        "y": 29
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{traffic=\"probe\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m]))",
          "legendFormat": "probe"
        },
        {
          "refId": "B",
          "expr": "sum(rate(http_requests_total{traffic=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\"}[5m]))",
          "legendFormat": "business"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "id": 16,
      "title": "Tool Summary Table",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 10,
        "w": 9,
        "x": 15,
        "y": 29
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool) (rate(mcp_tool_requests_total{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m]))",
          "legendFormat": "{{tool}} rps"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, tool) (rate(mcp_tool_request_duration_seconds_bucket{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m])))",
          "legendFormat": "{{tool}} p95"
        },
        {
          "refId": "C",
          "expr": "sum by (tool) (rate(mcp_tool_requests_total{traffic_type=\"business\",outcome=\"error\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m])) / clamp_min(sum by (tool) (rate(mcp_tool_requests_total{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"}[5m])), 0.001)",
          "legendFormat": "{{tool}} error_rate"
        },
        {
          "refId": "D",
          "expr": "sum by (tool) (mcp_tool_requests_in_flight{traffic_type=\"business\",namespace=~\"${namespace:regex}\",pod=~\"${pod:regex}\",tool=~\"${tool:regex}\"})",
          "legendFormat": "{{tool}} in_flight"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
